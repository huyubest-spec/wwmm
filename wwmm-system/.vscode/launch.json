{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: Backend (Go)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend",
      "cwd": "${workspaceFolder}/backend",
      "args": [],
      "env": {},
      "envFile": "${workspaceFolder}/backend/.env",
      "preLaunchTask": "build: Backend (Go)",
      "postDebugTask": "kill: wwmm processes",
      "presentation": {
        "group": "wwmm",
        "order": 1
      }
    },
    {
      "name": "Debug: Attach to wwmm-server",
      "type": "go",
      "request": "attach",
      "mode": "local",
      "processId": "${command:pickProcess}",
      "apiVersion": 2,
      "presentation": {
        "group": "wwmm",
        "order": 2
      },
      "detail": "先启动后端 (任务: run: Backend)，再 attach 上去调试"
    },
    {
      "name": "Run: Backend (no debug)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend",
      "cwd": "${workspaceFolder}/backend",
      "preLaunchTask": "build: Backend (Go)",
      "presentation": {
        "group": "wwmm",
        "order": 3
      },
      "detail": "直接运行后端（非调试模式）"
    }
  ],
  "compounds": [
    {
      "name": "▶ Start WWMM (Backend + Frontend)",
      "preLaunchTask": "wwmm: Start Backend + Frontend",
      "stopAll": true,
      "presentation": {
        "group": "wwmm",
        "order": 0
      },
      "detail": "一键启动后端 + 前端（推荐）"
    }
  ]
}
